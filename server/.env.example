# ─────────────────────────────────────────────────────────────────────────────
# Vigno Smart Class — backend environment
# Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=4000
# CORS: comma-separated list of allowed web origins (the Vite dev server)
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ─────────────────────────────────────────────────────────────────
# Atlas in prod: mongodb+srv://user:pass@cluster/vigno_smartclass
# Leave blank in dev to auto-use an in-memory MongoDB (mongodb-memory-server).
MONGO_URI=
# Force the in-memory DB even if MONGO_URI is set (handy for a clean demo)
USE_MEMORY_DB=true

# ── Auth (JWT in httpOnly cookies) ───────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
# Set true only when serving over HTTPS (prod)
COOKIE_SECURE=false

# ── License Authority (ES256 signing) ────────────────────────────────────────
# Stand-in for AWS KMS / Vault. Keys are generated into server/keys on first run.
# In prod, replace the keystore service with a KMS-backed signer (key never leaves).
LICENSE_KEY_DIR=./keys
LICENSE_ACTIVE_KID=vigno-key-2026
LICENSE_TTL=7d
# HMAC secret for short-lived signed file URLs (CloudFront-signed-URL stand-in)
SIGNED_URL_SECRET=change-me-signed-url-secret
# Separate secret for deriving per-content decryption keys (do NOT reuse the above)
CONTENT_KEY_SECRET=change-me-content-key-secret
SIGNED_URL_TTL_SECONDS=60

# ── Payments (Razorpay) ──────────────────────────────────────────────────────
# Leave blank in dev to use the built-in mock gateway (no real charges).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Storage (S3 stand-in) ────────────────────────────────────────────────────
# Local encrypted-at-rest stand-in for S3 (SSE-KMS) + CloudFront signed URLs.
STORAGE_DIR=./storage

# ── Bootstrap admin (created by `npm run seed`) ───────────────────────────────
SEED_ADMIN_EMAIL=admin@vigno.in
SEED_ADMIN_PASSWORD=Admin@12345
