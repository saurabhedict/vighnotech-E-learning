# ─────────────────────────────────────────────────────────────────────────────
# Vigno Smart Class — backend environment
# Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=4000
# CORS: comma-separated list of allowed web origins (the Vite dev server)
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ─────────────────────────────────────────────────────────────────
# Atlas in prod: mongodb+srv://user:pass@cluster/vigno_smartclass
# Leave blank in dev to auto-use an in-memory MongoDB (mongodb-memory-server).
MONGO_URI=
# Force the in-memory DB even if MONGO_URI is set (handy for a clean demo)
USE_MEMORY_DB=true

# ── Auth (JWT in httpOnly cookies) ───────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
# Set true only when serving over HTTPS (prod)
COOKIE_SECURE=false

# ── License Authority (ES256 signing) ────────────────────────────────────────
# Stand-in for AWS KMS / Vault. Keys are generated into server/keys on first run.
# In prod, replace the keystore service with a KMS-backed signer (key never leaves).
LICENSE_KEY_DIR=./keys
LICENSE_ACTIVE_KID=vigno-key-2026
LICENSE_TTL=7d
# HMAC secret for short-lived signed file URLs (CloudFront-signed-URL stand-in)
SIGNED_URL_SECRET=change-me-signed-url-secret
# Separate secret for deriving per-content decryption keys (do NOT reuse the above)
CONTENT_KEY_SECRET=change-me-content-key-secret
SIGNED_URL_TTL_SECONDS=60

# ── Payments (Razorpay) ──────────────────────────────────────────────────────
# Leave blank in dev to use the built-in mock gateway (no real charges).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Storage (local fallback) ─────────────────────────────────────────────────
# Used when AWS S3 below is NOT configured. Local encrypted-at-rest stand-in.
STORAGE_DIR=./storage

# ── AWS S3 (media object storage) ────────────────────────────────────────────
# Stores ALL uploaded media (pdf / video / 3d / game) in an S3 bucket. Leave
# AWS_S3_BUCKET blank in dev → the app automatically falls back to local disk
# (STORAGE_DIR above), so nothing breaks without credentials.
# >>> FILL THESE FOUR IN TO GO LIVE ON S3 <<<
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: prefix every object key, e.g. "media/" (keeps the bucket tidy).
AWS_S3_PREFIX=
# Optional: server-side-encryption-at-rest. "AES256" (SSE-S3, zero setup) or
# "aws:kms" (set AWS_S3_KMS_KEY_ID to your KMS key). Blank = AES256.
AWS_S3_SSE=AES256
AWS_S3_KMS_KEY_ID=
# Optional: custom endpoint for S3-compatible stores (MinIO / Cloudflare R2 /
# Wasabi). Leave blank for real AWS S3.
AWS_S3_ENDPOINT=

# ── AWS MediaConvert (adaptive HLS video transcoding) ─────────────────────────
# Transcodes uploaded videos into multi-bitrate HLS (.m3u8 + segments) in S3 for
# adaptive streaming. Requires the S3 block above to be configured too. Leave
# AWS_MEDIACONVERT_ROLE_ARN blank → videos just play as progressive MP4 (no
# transcode), so nothing breaks without it.
# Create an IAM ROLE that MediaConvert assumes (trust: mediaconvert.amazonaws.com)
# with read/write access to your S3 bucket, then paste its ARN here. The IAM USER
# (keys above) also needs: mediaconvert:CreateJob/GetJob/DescribeEndpoints + iam:PassRole.
AWS_MEDIACONVERT_ROLE_ARN=
# Optional: defaults to AWS_REGION.
AWS_MEDIACONVERT_REGION=
# Optional: leave blank to auto-discover the account-specific endpoint.
AWS_MEDIACONVERT_ENDPOINT=
# Optional: a specific MediaConvert queue ARN (blank = account default queue).
AWS_MEDIACONVERT_QUEUE_ARN=
# How long an HLS playback token stays valid (seconds). Long enough to watch a
# full video; it still expires. Default 14400 = 4 hours.
HLS_TOKEN_TTL_SECONDS=14400

# ── Cloudinary (profile photos) — blank = avatars stored inline as data URLs ──
# From your Cloudinary dashboard (https://console.cloudinary.com).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Cache (optional — Redis) ─────────────────────────────────────────────────
# Blank = in-memory cache (dev). Set to a redis:// URL to use Redis in prod.
REDIS_URL=

# ── Video DRM (optional — Widevine/FairPlay via Mux or VdoCipher) ─────────────
# Leave DRM_PROVIDER blank to disable (player falls back to standard HLS).
DRM_PROVIDER=
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
VDOCIPHER_API_SECRET=

# ── App identity (used in emails) ────────────────────────────────────────────
APP_NAME=Vigno Smart Class
APP_URL=http://localhost:5173

# ── Email (Nodemailer SMTP) ──────────────────────────────────────────────────
# Works with any provider: Gmail App Password, SendGrid, Mailgun, AWS SES,
# Resend, Mailtrap. Leave blank in dev → OTP/emails are printed to the server
# console (no email actually sent). >>> FILL THESE IN BEFORE GOING LIVE <<<
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Vigno Smart Class <no-reply@vigno.in>"

# ── OTP tuning (email OTP + authenticator TOTP) ──────────────────────────────
OTP_TTL_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# ── SMS + WhatsApp OTP (Twilio) ───────────────────────────────────────────────
# From the Twilio Console (https://console.twilio.com). Leave blank in dev →
# SMS/WhatsApp codes print to the server console (no message actually sent).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# A Twilio phone number you own, E.164 format, e.g. +12025550123
TWILIO_SMS_FROM=
# WhatsApp sender. Twilio sandbox default is whatsapp:+14155238886
# (the recipient must first join your sandbox). Keep the "whatsapp:" prefix.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Bootstrap admin (created by `npm run seed`) ───────────────────────────────
SEED_ADMIN_EMAIL=admin@vigno.in
SEED_ADMIN_PASSWORD=Admin@12345
